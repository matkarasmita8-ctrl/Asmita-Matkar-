# Write daily expenses to file
with open("expenses.txt", "w") as f:
    for i in range(1, 6):  # example: 5 days
        amt = float(input(f"Enter expense for day {i}: "))
        f.write(str(amt) + "\n")

# Read and calculate total
total = 0
with open("expenses.txt", "r") as f:
    for line in f:
        total += float(line.strip())

print("Total Monthly Expense:", total)
