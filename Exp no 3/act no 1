# A shop prints multiple copies of receipts use nested loops to print item numbers repeatedly
"""
Created on Tue Mar 24 11:11:09 2026

@author: Asmita 
"""

# Number of items
items = int(input("Enter number of items: "))

# Number of copies for each item
copies = int(input("Enter number of copies: "))

# Nested loops
for i in range(1, items + 1):          # Outer loop for items
    print(f"\nItem {i} receipts:")
    
    for j in range(1, copies + 1):    # Inner loop for copies
        print(f"Printing receipt copy {j} for Item {i}")
